@model LojaEcommerce.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
}

<h2 class="text-center mt-4">Editar Produto</h2>

<div class="container mt-5">

    <div class="card shadow p-4">

        <form method="post">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Nome</label>
                <input asp-for="Nome" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descrição</label>
                <textarea asp-for="Descricao" class="form-control"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Preço</label>
                <input asp-for="Preco" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Estoque</label>
                <input asp-for="Estoque" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Imagem</label>
                <input asp-for="Imagem" class="form-control" />
            </div>

            <div class="d-flex justify-content-between">

                <a href="/Produto/Gerenciar" class="btn btn-secondary">
                    Voltar
                </a>

                <button type="submit" class="btn btn-success">
                    Salvar Alterações
                </button>

            </div>

        </form>

    </div>

</div>