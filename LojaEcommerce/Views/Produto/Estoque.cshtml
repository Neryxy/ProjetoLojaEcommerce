@{
    ViewData["Title"] = "Controle de Estoque";

    var produtos = ViewBag.Produtos as List<Produto>;
}

<h2 class="text-center mt-4">Controle de Estoque</h2>

<div class="container mt-5">

    <div class="card shadow p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">Produtos em Estoque</h4>

            <a href="/Produto/Cadastrar" class="btn btn-success">
                Novo Produto
            </a>
        </div>

        @if (produtos != null && produtos.Count > 0)
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle text-center">

                    <thead class="table-warning">
                        <tr>
                            <th>Produto</th>
                            <th>Quantidade Atual</th>
                            <th>Atualizar Estoque</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var produto in produtos)
                        {
                            <tr>
                                <td>@produto.Nome</td>

                                <td>@produto.Estoque</td>

                                <td>
                                    <form asp-controller="Produto"
                                          asp-action="Estoque"
                                          method="post"
                                          class="d-flex gap-2 justify-content-center">

                                        <input type="hidden"
                                               name="id"
                                               value="@produto.Id" />

                                        <input type="number"
                                               name="estoque"
                                               class="form-control text-center"
                                               value="@produto.Estoque"
                                               min="0"
                                               style="max-width:120px;" />

                                        <button type="submit" class="btn btn-warning btn-sm">
                                            Atualizar
                                        </button>

                                    </form>
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="alert alert-warning text-center">
                Nenhum produto encontrado.
            </div>
        }

    </div>

</div>